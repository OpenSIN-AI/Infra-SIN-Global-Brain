    {
      "id": "rule-20260415-chrome-passwords-first",
      "type": "rule",
      "text": "IMMERS Chrome gespeicherte Passwörter VOR Nutzung verwenden! Chrome Password Manager (A2A-SIN-Google-Apps) enthält alle im Browser gespeicherten Logins. BEVOR ein Agent ein Passwort eingibt oder einen Login macht, MUSS er zuerst Chrome Password Manager prüfen! Niemals Menschen nach Passwörtern fragen!",
      "topic": "chrome-passwords-first",
      "status": "active",
      "scope": "global",
      "score": 1,
      "tags": ["chrome", "passwords", "automation", "never-ask-human"],
      "source": {
        "projectId": "opensin-documentation",
        "goalId": "chrome-password-auto-use",
        "sessionId": "session-20260415-opensin-documentation",
        "sourceType": "execution"
      },
      "rationale": "User hat viele Passwörter in Chrome gespeichert. Agenten sollen diese IMMER automatisch verwenden.",
