      "status": "active",
      "scope": "global",
      "score": 1,
      "tags": ["Dual-Logger", "SIN-InkogniFlow", "create-flow", "recording", "anti-bot", "Bézier-curve", "pynput", "CDP"],
      "source": {
        "projectId": "SIN-InkogniFlow",
        "goalId": "dual-logger-architecture",
        "sessionId": "session-20260413-dual-logger-build",
        "sourceType": "execution"
      },
      "rationale": "Provides structured machine-readable JSON workflow logs that combine OS-level and browser-level events with anti-bot replay countermeasures.",
